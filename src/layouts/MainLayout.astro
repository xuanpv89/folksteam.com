---
// Importing necessary components
import Meta from '@components/Meta.astro';
import Navbar from '@components/sections/navbar&footer/Navbar.astro';
import FooterSection from '@components/sections/navbar&footer/FooterSection.astro';
import { SITE } from '@data/constants';
import '@styles/global.css';

// Setting expected props
const {
  title = SITE.title,
  meta,
  structuredData,
  lang = 'en',
  customDescription = null,
  customOgTitle = null,
} = Astro.props;

// Interface to type-check the properties
interface Props {
  title?: string;
  meta?: string;
  structuredData?: object;
  lang?: string;
  customDescription?: string | null;
  customOgTitle?: string | null;
}
---

<html lang={lang} class="scrollbar-hide lenis lenis-smooth scroll-pt-16">
  <head>
    {/* Adding metadata to the HTML document */}
    <Meta
      meta={meta}
      structuredData={structuredData}
      customDescription={customDescription}
      customOgTitle={customOgTitle}
    />
    {/* Define the title of the page */}
    <title>{title}</title>
    <script is:inline>
      // Script to handle dark mode. It will check if the theme is stored in localStorage or if dark theme is preferred by system settings
      if (
        localStorage.getItem('hs_theme') === 'dark' ||
        (!('hs_theme' in localStorage) &&
          window.matchMedia('(prefers-color-scheme: dark)').matches)
      ) {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
    <script>
      import '@scripts/lenisSmoothScroll.js';
    </script>
  </head>
  <body
    class="flex min-h-screen flex-col bg-neutral-200 selection:bg-yellow-400 selection:text-neutral-700 dark:bg-neutral-800"
  >
    {
      /*
    Setting up the main structure of the page.
    The Navbar is placed at the top, with a slot for the main content and FooterSection at the bottom.
    */
    }
    <div
      class="mx-auto w-full max-w-(--breakpoint-2xl) grow px-4 sm:px-6 lg:px-8"
    >
      <Navbar />
      <main>
        <slot />
      </main>
    </div>
    <FooterSection />
    <script is:inline>
      (() => {
        const normalize = value => String(value || '').replace(/\s+/g, ' ').trim();
        const pagePath = window.location.pathname.replace(/\/$/, '') || '/';
        const skippedTags = new Set(['SCRIPT', 'STYLE', 'NOSCRIPT', 'SVG', 'CANVAS', 'IFRAME']);

        function collectTextNodes(root) {
          const nodes = [];
          const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
            acceptNode(node) {
              const parent = node.parentElement;
              if (!parent) return NodeFilter.FILTER_REJECT;
              if (skippedTags.has(parent.tagName)) return NodeFilter.FILTER_REJECT;
              if (parent.closest('[data-cms-ignore], nav, footer')) return NodeFilter.FILTER_REJECT;
              if (normalize(node.nodeValue).length < 2) return NodeFilter.FILTER_REJECT;
              return NodeFilter.FILTER_ACCEPT;
            },
          });

          while (walker.nextNode()) nodes.push(walker.currentNode);
          return nodes;
        }

        function applyElementField(field) {
          const key = String(field.key || '');
          const value = String(field.value ?? '');
          if (!value) return false;

          if (key.startsWith('link-')) {
            const links = [...document.querySelectorAll('main a[href]')];
            const index = Number(key.replace('link-', '')) - 1;
            const link = links[index];
            if (!link) return false;
            link.setAttribute('href', value);
            return true;
          }

          if (key.startsWith('image-')) {
            const images = [...document.querySelectorAll('main img')];
            const index = Number(key.replace('image-', '')) - 1;
            const image = images[index];
            if (!image) return false;
            image.setAttribute('src', value);
            image.removeAttribute('srcset');
            return true;
          }

          if (key.startsWith('alt-')) {
            const images = [...document.querySelectorAll('main img')];
            const index = Number(key.replace('alt-', '')) - 1;
            const image = images[index];
            if (!image) return false;
            image.setAttribute('alt', value);
            return true;
          }

          if (key === 'seo-title') {
            document.title = value;
            return true;
          }

          const metaName = key === 'seo-description' ? 'description' : '';
          if (metaName) {
            const meta = document.querySelector(`meta[name="${metaName}"]`);
            if (meta) meta.setAttribute('content', value);
            return true;
          }

          return false;
        }

        function pageMatches(page) {
          const candidate = String(page.path || '').replace(/\/$/, '') || '/';
          return candidate === pagePath;
        }

        async function applyCmsContent() {
          try {
            const response = await fetch('/cms-content.json', { credentials: 'same-origin' });
            if (!response.ok) return;

            const data = await response.json();
            const page = (data.pages || []).find(pageMatches);
            if (!page) return;

            const fields = (page.sections || []).flatMap(section => section.fields || []);
            if (!fields.length) return;

            const nodes = collectTextNodes(document.body);
            const used = new Set();

            fields.forEach(field => {
              const replacement = String(field.value ?? '');
              if (!replacement) return;

              if (applyElementField(field)) return;

              const original = normalize(field.match || field.original || '');
              let nodeIndex = -1;

              if (original) {
                nodeIndex = nodes.findIndex((node, index) => !used.has(index) && normalize(node.nodeValue) === original);
              }

              if (nodeIndex === -1 && /^text-\d+$/.test(field.key || '')) {
                const fallbackIndex = Number(String(field.key).replace('text-', '')) - 1;
                if (!used.has(fallbackIndex) && nodes[fallbackIndex]) nodeIndex = fallbackIndex;
              }

              if (nodeIndex === -1) return;

              nodes[nodeIndex].nodeValue = replacement;
              used.add(nodeIndex);
            });
          } catch {
            // CMS content is optional; public pages should keep rendering if it is unavailable.
          }
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', applyCmsContent, { once: true });
        } else {
          applyCmsContent();
        }
      })();
    </script>
    <script>
      // https://preline.co
      import 'preline';
      const init = () =>
        (
          window as Window & { HSStaticMethods?: { autoInit?: () => void } }
        ).HSStaticMethods?.autoInit?.();
      if (document.readyState === 'loading')
        document.addEventListener('DOMContentLoaded', init);
      else init();
    </script>
    <style>
      /* CSS rules for the page scrollbar */
      .scrollbar-hide::-webkit-scrollbar {
        display: none;
      }

      .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
    </style>
  </body>
</html>
