---
import MainLayout from '@/layouts/MainLayout.astro';
import PrimaryCTA from '@components/ui/buttons/PrimaryCTA.astro';
import CardSmall from '@components/ui/cards/CardSmall.astro';
import CardWide from '@components/ui/cards/CardWide.astro';
import FeaturesStatsAlt from '@components/sections/features/FeaturesStatsAlt.astro';
import TestimonialsSectionAlt from '@components/sections/testimonials/TestimonialsSectionAlt.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const product: CollectionEntry<'products'>[] = (
  await getCollection('products', ({ id }) => {
    return id.startsWith('vi/');
  })
).sort(
  (a: CollectionEntry<'products'>, b: CollectionEntry<'products'>) =>
    a.data.main.id - b.data.main.id
);

const title: string = 'Sản phẩm';
const subTitle: string =
  'Khám phá La Bàn Cảm Xúc: bộ thẻ và công cụ giúp gọi tên cảm xúc, quan sát tín hiệu bên trong và mở ra những cuộc trò chuyện sâu hơn.';

const testimonials = [
  {
    content:
      'La Bàn Cảm Xúc giúp buổi workshop trở nên dễ mở lời hơn. Người tham gia không cần diễn giải quá nhiều vẫn có thể chọn thẻ để bắt đầu chia sẻ.',
    author: 'Mai Anh',
    role: 'Facilitator | Community Lab',
    avatarSrc:
      'https://images.unsplash.com/photo-1544005313-94ddf0286df2?q=80&w=1376&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80',
    avatarAlt: 'Người dùng La Bàn Cảm Xúc',
  },
  {
    content:
      'Bộ thẻ làm cho việc nhận diện cảm xúc trở nên cụ thể. Nó rất hữu ích khi làm việc với đội nhóm, lớp học hoặc những buổi coaching một một.',
    author: 'Quang Minh',
    role: 'Coach | Growth Practice',
    avatarSrc:
      'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=1374&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80',
    avatarAlt: 'Coach sử dụng La Bàn Cảm Xúc',
  },
  {
    content:
      'Điểm hay nhất là sản phẩm không ép người dùng phải có câu trả lời đúng. Nó tạo một không gian an toàn để quan sát và gọi tên điều đang diễn ra.',
    author: 'Linh Đan',
    role: 'Learning Designer | Folks Team',
    avatarSrc:
      'https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=1374&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80',
    avatarAlt: 'Learning designer',
  },
];

const pageTitle = 'Sản phẩm | Folks Team';
const metaDescription =
  'La Bàn Cảm Xúc là bộ công cụ giúp nhận diện, gọi tên và trò chuyện về cảm xúc một cách rõ ràng hơn.';
const ogTitle = 'La Bàn Cảm Xúc | Folks Team';
---

<MainLayout
  title={pageTitle}
  lang="vi"
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://folksteam.com/vi/products',
    url: 'https://folksteam.com/vi/products',
    name: 'La Bàn Cảm Xúc | Folks Team',
    description: metaDescription,
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://folksteam.com/vi',
      name: 'Folks Team',
      description:
        'Folks Team xây hệ thống tăng trưởng hiện đại dựa trên C.H.E.S.S.',
    },
    inLanguage: 'vi',
  }}
>
  <div
    class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
  >
    <div class="mb-4 flex items-center justify-between gap-8 sm:mb-8 md:mb-12">
      <div class="flex items-center gap-12">
        <h1
          class="text-2xl font-bold tracking-tight text-balance text-neutral-800 md:text-4xl md:leading-tight dark:text-neutral-200"
        >
          {title}
        </h1>
        {
          subTitle && (
            <p class="hidden max-w-(--breakpoint-sm) text-pretty text-neutral-600 md:block dark:text-neutral-400">
              {subTitle}
            </p>
          )
        }
      </div>
      <PrimaryCTA title="Câu chuyện người dùng" url="#testimonials" noArrow={true} />
    </div>

    <section class="grid grid-cols-1 gap-4 sm:grid-cols-3 md:gap-6 xl:gap-8">
      {
        product.map((product, index) => {
          const position = index % 4;
          if (position === 0 || position === 3) {
            return <CardSmall product={product} productLocale="vi" />;
          } else {
            return <CardWide product={product} productLocale="vi" />;
          }
        })
      }
    </section>
  </div>

  <FeaturesStatsAlt
    title="Vì sao chọn La Bàn Cảm Xúc?"
    subTitle="Một công cụ trực quan để biến cảm xúc từ điều mơ hồ thành ngôn ngữ có thể chia sẻ, quan sát và thực hành."
    benefits={[
      'Giúp người dùng gọi tên cảm xúc nhanh hơn và chính xác hơn.',
      'Phù hợp cho workshop, coaching, giáo dục, đội nhóm và tự quan sát.',
      'Thiết kế mở, dễ kết hợp với journaling, check-in, debrief và hoạt động nhóm.',
    ]}
  />

  <TestimonialsSectionAlt
    title="Người dùng nói gì"
    testimonials={testimonials}
  />
</MainLayout>
