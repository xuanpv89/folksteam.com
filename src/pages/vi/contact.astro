---
import MainLayout from '@/layouts/MainLayout.astro';
import ContactSection from '@components/sections/vi/ContactSection_vi.astro';
import { SITE } from '@data/constants';

const pageTitle: string = `Liên hệ | ${SITE.title}`;
const metaDescription =
  'Trao đổi với Folks Team về C.H.E.S.S, hệ thống tăng trưởng hoặc La Bàn Cảm Xúc.';
const ogTitle = 'Liên hệ | Folks Team';
---

<MainLayout
  title={pageTitle}
  lang="vi"
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://folks-team.com/vi/contact',
    url: 'https://folks-team.com/vi/contact',
    name: 'Liên hệ | Folks Team',
    description: metaDescription,
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://folks-team.com/vi/',
      name: 'Folks Team',
      description:
        'Folks Team xây hệ thống tăng trưởng hiện đại dựa trên C.H.E.S.S.',
    },
    inLanguage: 'vi',
  }}
>
  <ContactSection />
</MainLayout>
