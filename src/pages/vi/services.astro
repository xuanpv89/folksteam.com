---
import MainLayout from '@/layouts/MainLayout.astro';
import MainSection from '@components/ui/blocks/MainSection.astro';
import LeftSection from '@components/ui/blocks/LeftSection.astro';
import RightSection from '@components/ui/blocks/RightSection.astro';
import FeaturesStats from '@components/sections/features/FeaturesStats.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';

import strategyImage from '@images/growth-brainstorm.jpg';
import workshopImage from '@images/growth-workshop.jpg';
import analyticsImage from '@images/growth-analytics.jpg';
import brandMark from '@images/folks-brand-mark.jpg';
import brandLogo from '@images/folks-brand-logo.png';

interface Article {
  isRightSection: boolean;
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  single?: boolean;
  img?: any;
  imgAlt?: string;
  imgOne?: any;
  imgOneAlt?: string;
  imgTwo?: any;
  imgTwoAlt?: string;
}

const articles: Article[] = [
  {
    isRightSection: true,
    title: 'Tư vấn chiến lược C.H.E.S.S',
    subTitle:
      'Chúng tôi giúp bạn xác định positioning, audience, thông điệp và hướng tăng trưởng trước khi lao vào thực thi. Mục tiêu là tạo một bản đồ rõ ràng để mọi hoạt động marketing, content và community đi cùng một hướng.',
    single: false,
    imgOne: strategyImage,
    imgOneAlt: 'Đội nhóm đang xây chiến lược tăng trưởng',
    imgTwo: brandMark,
    imgTwoAlt: 'Dấu hiệu nhận diện Folks Team',
  },
  {
    isRightSection: false,
    title: 'Thiết kế hệ thống content và hub',
    subTitle:
      'Từ ý tưởng rời rạc, chúng tôi giúp bạn xây content engine, hub tài nguyên và quy trình xuất bản để biến nội dung thành tài sản tăng trưởng dài hạn.',
    img: workshopImage,
    imgAlt: 'Workshop xây dựng hệ thống nội dung',
    btnExists: true,
    btnTitle: 'Xem sản phẩm',
    btnURL: '/vi/products',
  },
  {
    isRightSection: true,
    title: 'Tích hợp cộng đồng và ecosystem',
    subTitle:
      'Cộng đồng không chỉ là nơi đăng bài. Chúng tôi giúp thiết kế vòng lặp tương tác, điểm chạm, feedback và hệ sinh thái đối tác để tăng trưởng có chiều sâu hơn.',
    single: false,
    imgOne: analyticsImage,
    imgOneAlt: 'Dashboard đo lường tăng trưởng',
    imgTwo: brandLogo,
    imgTwoAlt: 'Logo Folks Team',
  },
  {
    isRightSection: false,
    title: 'Vận hành và tối ưu liên tục',
    subTitle:
      'Sau khi hệ thống đi vào hoạt động, chúng tôi hỗ trợ đo lường, review, tối ưu workflow và điều chỉnh ưu tiên dựa trên dữ liệu, phản hồi và năng lực đội ngũ.',
    img: analyticsImage,
    imgAlt: 'Phân tích dữ liệu tăng trưởng',
  },
  {
    isRightSection: true,
    title: 'Workshop La Bàn Cảm Xúc',
    subTitle:
      'Với các đội nhóm cần cải thiện giao tiếp và thấu hiểu, chúng tôi có thể thiết kế workshop sử dụng La Bàn Cảm Xúc để mở đối thoại an toàn, cụ thể và giàu tính con người.',
    single: false,
    imgOne: brandMark,
    imgOneAlt: 'Hệ màu nhận diện Folks Team',
    imgTwo: workshopImage,
    imgTwoAlt: 'Không gian workshop đội nhóm',
    btnExists: true,
    btnTitle: 'Liên hệ tư vấn',
    btnURL: '/vi/contact',
  },
];
---

<MainLayout
  title="Dịch vụ | Folks Team"
  lang="vi"
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://folksteam.com/vi/services',
    url: 'https://folksteam.com/vi/services',
    name: 'Dịch vụ tăng trưởng | Folks Team',
    description:
      'Dịch vụ tư vấn và triển khai hệ thống tăng trưởng dựa trên C.H.E.S.S cho marketing, content, community và vận hành.',
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://folksteam.com/vi',
      name: 'Folks Team',
      description:
        'Folks Team xây hệ thống tăng trưởng hiện đại dựa trên C.H.E.S.S.',
    },
    inLanguage: 'vi',
  }}
>
  <MainSection
    title="Biến tăng trưởng thành một hệ thống có thể vận hành"
    subTitle="Folks Team giúp bạn kết nối chiến lược, content, cộng đồng và vận hành thành một mô hình tăng trưởng rõ ràng, thực tế và có thể mở rộng."
    btnExists={true}
    btnTitle="Bắt đầu trao đổi"
    btnURL={getRelativeLocaleUrl('vi', 'contact')}
  />

  {
    articles.map(article => {
      return article.isRightSection ? (
        <RightSection
          title={article.title}
          subTitle={article.subTitle}
          single={article.single}
          imgOne={article.imgOne}
          imgOneAlt={article.imgOneAlt}
          imgTwo={article.imgTwo}
          imgTwoAlt={article.imgTwoAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      ) : (
        <LeftSection
          title={article.title}
          subTitle={article.subTitle}
          img={article.img}
          imgAlt={article.imgAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      );
    })
  }

  <FeaturesStats
    title="Tăng trưởng bằng hệ thống"
    subTitle="Dịch vụ của Folks Team tập trung vào clarity, cấu trúc và khả năng lặp lại, để đội ngũ không phải phụ thuộc vào cảm hứng ngắn hạn."
    mainStatTitle="96%"
    mainStatSubTitle="khách hàng đánh giá cao sự rõ ràng sau buổi strategy review"
    stats={[
      {
        stat: '5+',
        description: 'lớp C.H.E.S.S được kết nối trong một hệ thống',
      },
      {
        stat: '24.8K',
        description: 'workflow và hệ thống mẫu được tạo',
      },
      {
        stat: '132K',
        description: 'builder đang theo đuổi tăng trưởng có cấu trúc',
      },
    ]}
  />
</MainLayout>
