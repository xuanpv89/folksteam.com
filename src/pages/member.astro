---
import MainLayout from '@/layouts/MainLayout.astro';

const benefits = [
  ['Learning paths', 'Follow guided C.H.E.S.S tracks for content, community, events, offers, and sessions.'],
  ['Templates library', 'Use checklists, canvases, and operating tools for building a repeatable growth system.'],
  ['Community room', 'Join member discussions, exchange feedback, and learn from other builders.'],
  ['Compassio practice', 'Access reflective prompts that help teams build language for emotion, listening, and trust.'],
];

const memberRoles = [
  ['Builder', 'For founders, creators, and operators designing their first structured growth system.'],
  ['Facilitator', 'For coaches, teachers, and community leads running workshops or learning circles.'],
  ['Team', 'For organizations aligning content, events, offers, and member experience around one model.'],
];
---

<MainLayout title="Member | Folks Team">
  <section class="mx-auto grid max-w-[85rem] gap-10 px-4 py-16 sm:px-6 lg:grid-cols-[1fr_.9fr] lg:px-8 lg:py-24">
    <div class="flex flex-col justify-center">
      <p class="text-sm font-black uppercase tracking-widest text-yellow-600 dark:text-yellow-400">Member Portal</p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-neutral-900 md:text-6xl dark:text-neutral-100">
        Build your growth system with structure, support, and practice.
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-neutral-600 dark:text-neutral-400">
        The Folks member area is designed as a practical workspace for people applying C.H.E.S.S: learning paths, reusable tools, community feedback, and reflective Compassio practice.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/contact" class="inline-flex rounded-lg bg-yellow-500 px-6 py-3 text-sm font-bold text-white transition hover:bg-yellow-600">
          Request access
        </a>
        <a href="/guides/getting-started/" class="inline-flex rounded-lg border border-neutral-300 px-6 py-3 text-sm font-bold text-neutral-800 transition hover:bg-neutral-100 dark:border-neutral-700 dark:text-neutral-200 dark:hover:bg-neutral-800">
          View guides
        </a>
      </div>
    </div>
    <div class="overflow-hidden rounded-2xl bg-neutral-100 dark:bg-neutral-900">
      <img
        src="https://images.unsplash.com/photo-1556761175-b413da4baf72?auto=format&fit=crop&w=1200&q=85"
        alt="Folks Team member workspace"
        class="h-full min-h-[420px] w-full object-cover"
      />
    </div>
  </section>

  <section class="bg-neutral-100 px-4 py-14 dark:bg-neutral-900">
    <div class="mx-auto max-w-[85rem] sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h2 class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">What members can use</h2>
        <p class="mt-3 text-neutral-600 dark:text-neutral-400">
          The portal keeps growth work organized so members can move from ideas to repeatable action.
        </p>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
        {
          benefits.map(([title, description]) => (
            <article class="rounded-xl bg-white p-6 dark:bg-neutral-800">
              <h3 class="font-bold text-neutral-900 dark:text-neutral-100">{title}</h3>
              <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">{description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[85rem] px-4 py-14 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-[.8fr_1.2fr] lg:items-start">
      <div>
        <p class="text-sm font-black uppercase tracking-widest text-yellow-600 dark:text-yellow-400">Designed for</p>
        <h2 class="mt-3 text-3xl font-bold text-neutral-900 dark:text-neutral-100">Different members, one shared model</h2>
      </div>
      <div class="grid gap-4">
        {
          memberRoles.map(([title, description]) => (
            <article class="rounded-xl border border-neutral-200 p-6 dark:border-neutral-700">
              <h3 class="font-bold text-neutral-900 dark:text-neutral-100">{title}</h3>
              <p class="mt-2 text-neutral-600 dark:text-neutral-400">{description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</MainLayout>
