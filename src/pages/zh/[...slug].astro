type PageKey = keyof typeof pages;
const rawSlug = Astro.params.slug ?? 'about';
const slug = (rawSlug === 'projects/compassio'
  ? 'compassio'
  : rawSlug.split('/')[0]) as PageKey;
const page = pages[slug];
const pageTitle = `${page.title} | ${SITE.title}`;
---

<MainLayout
  title={pageTitle}
  lang="zh-CN"
  customDescription={page.description}
  customOgTitle={page.title}
>
  <section class="pt-16 pb-12 md:pt-24">
    <div class="grid gap-10 lg:grid-cols-[.95fr_1.05fr] lg:items-center">
      <div>
        <p class="text-sm font-black uppercase tracking-widest text-green-600">
          {page.eyebrow}
        </p>
        <h1 class="mt-4 text-4xl font-black leading-tight text-neutral-900 md:text-6xl dark:text-neutral-50">
          {page.title}
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-neutral-700 dark:text-neutral-300">
          {page.description}
        </p>
      </div>
      <div class="overflow-hidden rounded-[28px] bg-neutral-900 shadow-2xl">
        <img src={page.image} alt={page.title} class="h-full min-h-[360px] w-full object-cover opacity-90" />
      </div>
    </div>
  </section>

  <section class="grid gap-5 py-10 md:grid-cols-2">
    {page.sections.map(section => (
      <article class="rounded-lg border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-700 dark:bg-neutral-900">
        <h2 class="text-2xl font-black text-neutral-900 dark:text-neutral-50">{section.title}</h2>
        <ul class="mt-5 space-y-3">
          {section.items.map(item => (
            <li class="flex gap-3 text-neutral-700 dark:text-neutral-300">
              <span class="mt-2 h-2 w-2 flex-none rounded-full bg-green-600"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </article>
    ))}
  </section>

  {'team' in page && (
    <section id="team" class="py-12">
      <div class="mb-8 max-w-3xl">
        <p class="text-sm font-black uppercase tracking-widest text-yellow-600">
          Team
        </p>
        <h2 class="mt-3 text-3xl font-black text-neutral-900 md:text-5xl dark:text-neutral-50">
          Folks Team 的核心角色
        </h2>
      </div>
      <div class="grid gap-5 md:grid-cols-4">
        {page.team.map(([role, summary], index) => (
          <article class="rounded-lg bg-white p-5 shadow-sm dark:bg-neutral-900">
            <img
              src={`https://images.unsplash.com/photo-${[
                '1560250097-0b93528c311a',
                '1494790108377-be9c29b29330',
                '1507003211169-0a1dd7228f2d',
                '1551836022-d5d88e9218df',
              ][index]}?auto=format&fit=facearea&facepad=2&w=480&h=480&q=80`}
              alt={role}
              class="h-48 w-full rounded-lg object-cover"
            />
            <h3 class="mt-4 text-lg font-black text-neutral-900 dark:text-neutral-50">{role}</h3>
            <p class="mt-2 text-sm leading-6 text-neutral-600 dark:text-neutral-400">{summary}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  {'contact' in page && (
    <section class="py-10">
      <form id="zh-contact-form" class="grid gap-4 rounded-lg bg-white p-6 shadow-sm dark:bg-neutral-900">
        <input type="hidden" name="locale" value="zh" />
        <label class="grid gap-2 text-sm font-bold text-neutral-800 dark:text-neutral-200">
          姓名
          <input required name="name" class="rounded-lg border border-neutral-300 px-4 py-3 dark:border-neutral-700 dark:bg-neutral-950" />
        </label>
        <label class="grid gap-2 text-sm font-bold text-neutral-800 dark:text-neutral-200">
          Email
          <input required type="email" name="email" class="rounded-lg border border-neutral-300 px-4 py-3 dark:border-neutral-700 dark:bg-neutral-950" />
        </label>
        <label class="grid gap-2 text-sm font-bold text-neutral-800 dark:text-neutral-200">
          你想讨论什么？
          <textarea required name="message" rows="6" class="rounded-lg border border-neutral-300 px-4 py-3 dark:border-neutral-700 dark:bg-neutral-950"></textarea>
        </label>
        <button type="submit" class="w-fit rounded-lg bg-green-600 px-5 py-3 text-sm font-bold text-white transition hover:bg-green-700">
          发送
        </button>
        <p id="zh-contact-status" class="text-sm text-neutral-600 dark:text-neutral-400"></p>
      </form>
    </section>
  )}

  {'newsletter' in page && <NewsletterSignup locale="zh" />}

  <section class="my-14 rounded-[28px] bg-neutral-950 p-8 text-white md:p-12">
    <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
      <h2 class="text-3xl font-black md:text-5xl">
        想把这个系统应用到你的组织？
      </h2>
      <a href="/zh/contact" class="rounded-lg bg-green-600 px-5 py-3 text-sm font-bold text-white transition hover:bg-green-700">
        联系 Folks Team
      </a>
    </div>
  </section>
</MainLayout>

<script>
  const form = document.getElementById('zh-contact-form') as HTMLFormElement | null;
  const status = document.getElementById('zh-contact-status');

  form?.addEventListener('submit', async event => {
    event.preventDefault();
    if (!status) return;

    status.textContent = '正在发送...';
    const response = await fetch('/api/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams(
        Array.from(new FormData(form).entries()) as string[][]
      ),
    });

    status.textContent = response.ok
      ? '已发送，我们会尽快回复。'
      : '发送失败，请直接邮件 contact@folksteam.com。';
    if (response.ok) form.reset();
  });
</script>
