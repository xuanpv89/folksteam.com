---
import MainLayout from '@/layouts/MainLayout.astro';
import NewsletterSignup from '@components/sections/misc/NewsletterSignup.astro';
import { SITE } from '@data/constants';

export function getStaticPaths() {
  const routes = [
    'about',
    'services',
    'chess',
    'compassio',
    'projects/compassio',
    'contact',
    'member',
    'blog',
    'products',
    'insights',
    ...Array.from({ length: 11 }, (_, index) => `blog/post-${index + 1}`),
    'products/item-a765',
    'products/item-b203',
    'products/item-f303',
    'products/item-t845',
    'insights/insight-1',
    'insights/insight-2',
    'insights/insight-3',
  ];

  return routes.map(slug => ({ params: { slug } }));
}

const pages = {
