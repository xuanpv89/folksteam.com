---
import MainLayout from '@/layouts/MainLayout.astro';
import { SITE } from '@data/constants';

const pageTitle = `首页 | ${SITE.title}`;
const metaDescription =
  'Folks Team 帮助教育、文化与创意组织用 C.H.E.S.S 模型建立内容、社群、体验与可持续增长系统。';

const pillars = [
  ['Content', '把洞察、课程、案例与故事转化为可以持续传播的内容资产。'],
  ['Hub', '建立网站、社群入口与知识库，让受众知道从哪里开始。'],
  ['Event', '设计工作坊、体验课、沙龙与线上活动，创造真实互动。'],
  ['Store', '把产品、服务与项目整理成清晰的购买路径。'],
  ['Session', '通过顾问、引导与复盘，把一次接触变成长期关系。'],
];

const videos = [
  {
    title: 'Demo video：学习内容格式',
    embed: 'https://www.youtube-nocookie.com/embed/jNQXAC9IVRw',
  },
  {
    title: 'Demo video：社区叙事格式',
    embed: 'https://www.youtube-nocookie.com/embed/ysz5S6PUM-U',
  },
  {
    title: 'Demo video：反思工具展示格式',
    embed: 'https://www.youtube-nocookie.com/embed/jNQXAC9IVRw',
  },
];
---

<MainLayout
  title={pageTitle}
  lang="zh-CN"
  customDescription={metaDescription}
  customOgTitle="Folks Team | C.H.E.S.S 增长系统"
>
  <section class="pt-16 pb-12 md:pt-24">
    <div class="grid gap-10 lg:grid-cols-[1.05fr_.95fr] lg:items-center">
      <div>
        <p class="text-sm font-black uppercase tracking-widest text-green-600">
          Folks Team
        </p>
        <h1 class="mt-4 max-w-4xl text-5xl font-black leading-[1.02] text-neutral-900 md:text-7xl dark:text-neutral-50">
          为现代组织建立可持续的内容与社群增长系统
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-neutral-700 dark:text-neutral-300">
          我们结合策略、内容、体验设计与 C.H.E.S.S 模型，帮助团队把品牌表达、学习体验、社群关系与业务转化连接成一个清晰系统。
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/zh/chess" class="rounded-lg bg-green-600 px-5 py-3 text-sm font-bold text-white transition hover:bg-green-700">
            了解 C.H.E.S.S
          </a>
          <a href="/zh/contact" class="rounded-lg border border-neutral-300 px-5 py-3 text-sm font-bold text-neutral-900 transition hover:bg-neutral-100 dark:border-neutral-700 dark:text-neutral-100 dark:hover:bg-neutral-800">
            联系我们
          </a>
        </div>
      </div>
      <div class="overflow-hidden rounded-[28px] bg-neutral-900 shadow-2xl">
        <img
          src="https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=1400&q=80"
          alt="团队在工作坊中协作"
          class="h-full min-h-[420px] w-full object-cover opacity-90"
        />
      </div>
    </div>
  </section>

  <section class="py-14">
    <div class="mb-8 max-w-3xl">
      <p class="text-sm font-black uppercase tracking-widest text-yellow-600">
        C.H.E.S.S model
      </p>
      <h2 class="mt-3 text-3xl font-black text-neutral-900 md:text-5xl dark:text-neutral-50">
        把增长拆成可管理的五个层级
      </h2>
    </div>
    <div class="grid gap-4 md:grid-cols-5">
      {pillars.map(([title, text]) => (
        <article class="rounded-lg border border-neutral-200 bg-white p-5 shadow-sm dark:border-neutral-700 dark:bg-neutral-900">
          <h3 class="text-xl font-black text-neutral-900 dark:text-neutral-50">{title}</h3>
          <p class="mt-3 text-sm leading-6 text-neutral-600 dark:text-neutral-400">{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="py-14">
    <div class="grid gap-8 lg:grid-cols-[.85fr_1.15fr] lg:items-start">
      <div>
        <p class="text-sm font-black uppercase tracking-widest text-green-600">
          Compassio gallery
        </p>
        <h2 class="mt-3 text-3xl font-black text-neutral-900 md:text-5xl dark:text-neutral-50">
          用真实内容展示情绪识读与社群学习
        </h2>
        <p class="mt-4 text-neutral-700 dark:text-neutral-300">
          Compassio 的公开视频可以作为内容引擎的一部分，帮助受众先理解方法，再进入工作坊、课程与社群体验。
        </p>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {videos.map(video => (
          <article class="overflow-hidden rounded-lg bg-white shadow-sm dark:bg-neutral-900">
            <iframe
              class="aspect-video w-full"
              src={video.embed}
              title={video.title}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
            <h3 class="p-4 text-sm font-bold text-neutral-900 dark:text-neutral-100">{video.title}</h3>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="my-14 rounded-[28px] bg-neutral-950 p-8 text-white md:p-12">
    <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
      <div>
        <p class="text-sm font-black uppercase tracking-widest text-yellow-400">
          Work with us
        </p>
        <h2 class="mt-3 text-3xl font-black md:text-5xl">
          从策略到内容、活动、产品与社群运营，我们一起把系统落地。
        </h2>
      </div>
      <a href="/zh/contact" class="rounded-lg bg-green-600 px-5 py-3 text-sm font-bold text-white transition hover:bg-green-700">
        开始讨论
      </a>
    </div>
  </section>
</MainLayout>
