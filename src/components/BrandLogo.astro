---
import { Image } from 'astro:assets';
import folksMark from '@images/folks-brand-mark.jpg';

const { class: className = '' } = Astro.props;
---

<span
  class:list={[
    className,
    'inline-flex items-center gap-2 whitespace-nowrap font-bold tracking-tight text-neutral-800 dark:text-neutral-100',
  ]}
>
  <Image
    src={folksMark}
    alt="Folks logo"
    width={28}
    height={28}
    class="size-7 rounded-sm object-cover"
    loading="eager"
    format="webp"
  />
  FOLKS TEAM
</span>
