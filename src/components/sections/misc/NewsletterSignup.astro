---
const {
  locale = Astro.currentLocale === 'vi'
    ? 'vi'
    : Astro.currentLocale === 'zh'
      ? 'zh'
      : 'en',
  compact = false,
  variant = 'default',
  id = compact ? `newsletter-email-compact-${locale}` : `newsletter-email-${locale}`,
} = Astro.props;

interface Props {
  locale?: 'en' | 'vi' | 'zh';
  compact?: boolean;
  variant?: 'default' | 'footer';
  id?: string;
}

const copyByLocale = {
  en: {
    eyebrow: 'Newsletter',
    title: 'Get new writing from Folks Team',
    description:
      'Subscribe for practical notes on C.H.E.S.S, community, content, and sustainable growth systems.',
    footerDescription: 'Get new notes on C.H.E.S.S and growth systems.',
    placeholder: 'Your email',
    button: 'Subscribe',
    note: 'Useful updates only. No spam.',
    subject: 'New Folks Team newsletter signup',
  },
  vi: {
    eyebrow: 'Newsletter',
    title: 'Nhận bài viết mới từ Folks Team',
    description:
      'Đăng ký để nhận bài viết về C.H.E.S.S, cộng đồng, nội dung và hệ thống tăng trưởng bền vững.',
    footerDescription: 'Nhận bài viết mới về C.H.E.S.S và growth systems.',
    placeholder: 'Email của bạn',
    button: 'Đăng ký',
    note: 'Chúng tôi chỉ gửi nội dung hữu ích, không spam.',
    subject: 'Đăng ký newsletter mới từ website Folks Team',
  },
  zh: {
    eyebrow: 'Newsletter',
    title: '接收 Folks Team 最新文章',
    description:
      '订阅 C.H.E.S.S、社群、内容系统与可持续增长实践的实用笔记。',
    footerDescription: '接收关于 C.H.E.S.S 与增长系统的新文章。',
    placeholder: '你的邮箱',
    button: '订阅',
    note: '只发送有价值的更新，不发送垃圾邮件。',
    subject: 'Folks Team 网站新的 newsletter 订阅',
  },
};

const copy = copyByLocale[locale as keyof typeof copyByLocale] ?? copyByLocale.en;
const description =
  variant === 'footer' ? copy.footerDescription : copy.description;
---

<section
  class:list={[
    variant === 'footer'
      ? 'max-w-sm rounded-lg bg-neutral-200/50 p-3 dark:bg-neutral-800/60'
      : compact
        ? 'rounded-xl border border-neutral-200 bg-white p-5 dark:border-neutral-700 dark:bg-neutral-800'
        : 'mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 2xl:max-w-full',
  ]}
>
  <div
    class:list={[
      compact
        ? ''
        : 'rounded-2xl bg-neutral-900 p-6 md:grid md:grid-cols-[1fr_auto] md:items-center md:gap-8 md:p-8 dark:bg-neutral-950',
    ]}
  >
    <div>
      <p
        class:list={[
          'text-sm font-black uppercase tracking-widest',
          compact || variant === 'footer'
            ? 'text-yellow-600 dark:text-yellow-400'
            : 'text-yellow-400',
        ]}
      >
        {copy.eyebrow}
      </p>
      <h2
        class:list={[
          'mt-2 font-bold',
          variant === 'footer'
            ? 'text-base text-neutral-900 dark:text-neutral-100'
            : compact
              ? 'text-lg text-neutral-900 dark:text-neutral-100'
              : 'text-2xl text-white md:text-3xl',
        ]}
      >
        {copy.title}
      </h2>
      <p
        class:list={[
          'mt-2',
          compact || variant === 'footer'
            ? 'text-sm text-neutral-600 dark:text-neutral-400'
            : 'max-w-2xl text-neutral-300',
        ]}
      >
        {description}
      </p>
    </div>

    <form
      action="/api/newsletter"
      method="POST"
      data-newsletter-form
      class:list={[
        'mt-5 flex gap-2',
        variant === 'footer'
          ? 'mt-4 flex-col gap-2'
          : compact
            ? 'flex-col'
            : 'flex-col sm:flex-row md:mt-0',
      ]}
    >
      <input type="hidden" name="locale" value={locale} />
      <input
        type="hidden"
        name="source"
        value={variant === 'footer'
          ? 'footer-signup'
          : compact
            ? 'compact-signup'
            : 'newsletter-section'}
      />
      <label class="sr-only" for={id}>
        {copy.placeholder}
      </label>
      <input
        id={id}
        type="email"
        name="email"
        required
        autocomplete="email"
        placeholder={copy.placeholder}
        class:list={[
          'min-h-12 rounded-lg border border-neutral-300 px-4 text-sm outline-hidden focus:border-yellow-500 focus:ring-2 focus:ring-yellow-500 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-100',
          variant === 'footer'
            ? 'min-h-10 w-full px-3'
            : compact
              ? 'w-full'
              : 'w-full sm:w-72',
        ]}
      />
      <button
        type="submit"
        class:list={[
          'rounded-lg bg-yellow-500 text-sm font-bold text-white transition hover:bg-yellow-600',
          variant === 'footer' ? 'min-h-10 px-4' : 'min-h-12 px-5',
        ]}
      >
        {copy.button}
      </button>
    </form>

    <p
      data-newsletter-status
      class:list={[
        'mt-3 text-xs',
        compact || variant === 'footer'
          ? 'text-neutral-500 dark:text-neutral-500'
          : 'text-neutral-400 md:col-span-2',
      ]}
    >
      {copy.note}
    </p>
  </div>
</section>

<script is:inline>
  if (!window.__folksNewsletterHandlerAttached) {
    window.__folksNewsletterHandlerAttached = true;
    document.addEventListener('submit', async event => {
    const form = event.target;
    if (!(form instanceof HTMLFormElement) || !form.matches('[data-newsletter-form]')) return;

    event.preventDefault();

    const status = form.parentElement?.querySelector('[data-newsletter-status]');
    const submit = form.querySelector('button[type="submit"]');
    const originalText = status?.textContent || '';

    if (status) {
      status.textContent = 'Submitting...';
      status.className = 'mt-3 text-xs font-semibold text-yellow-700 dark:text-yellow-300';
    }
    if (submit instanceof HTMLButtonElement) submit.disabled = true;

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new URLSearchParams(new FormData(form)),
        headers: {
          Accept: 'application/json',
          'Content-Type': 'application/x-www-form-urlencoded',
        },
      });
      const result = await response.json();

      if (!response.ok || !result.ok) {
        throw new Error(result.message || 'Unable to subscribe.');
      }

      form.reset();
      if (status) {
        status.textContent = result.message;
        status.className = 'mt-3 text-xs font-semibold text-green-700 dark:text-green-300';
      }
    } catch (error) {
      if (status) {
        status.textContent =
          error instanceof Error ? error.message : 'Unable to subscribe.';
        status.className = 'mt-3 text-xs font-semibold text-red-700 dark:text-red-300';
      }
    } finally {
      if (submit instanceof HTMLButtonElement) submit.disabled = false;
      if (status) {
        setTimeout(() => {
          status.textContent = originalText;
          status.className = 'mt-3 text-xs text-neutral-500 dark:text-neutral-500';
        }, 7000);
      }
    }
  });
  }
</script>
