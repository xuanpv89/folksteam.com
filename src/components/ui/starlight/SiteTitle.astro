---
import brandMark from '@images/folks-brand-mark.jpg';
import type { Props } from '@astrojs/starlight/props';

const main = '/';
const locale = Astro.props.locale ? Astro.props.locale + '/' : '';
const docs = '/' + locale + 'welcome-to-docs/';
---

<span class="site-title flex">
  <a class="brand-link" href={main} aria-label="Folks Team">
    <img src={brandMark.src} alt="" class="brand-mark" />
    <span class="brand-name">FOLKS</span>
  </a>
  <a class="docs-link" href={docs} aria-label="Folks Team Docs">docs</a>
</span>

<style>
  .site-title {
    gap: 0.9rem;
    margin-right: 1rem;
  }
  .site-title a {
    display: flex;
  }
  .brand-link,
  .docs-link {
    align-items: center;
    color: var(--sl-color-white);
    text-decoration: none;
  }
  .brand-mark {
    width: 2.35rem;
    height: 2.35rem;
    border-radius: 0.25rem;
    object-fit: cover;
  }
  .brand-name {
    margin-left: 0.65rem;
    font-size: 1.35rem;
    font-weight: 900;
    letter-spacing: 0;
  }
  .docs-link {
    font-size: 1.65rem;
    font-weight: 800;
  }

  .flex {
    display: flex;
    align-items: center;
  }
  .site-title a:focus-visible {
    outline: 0;
  }
  .site-title a:focus-visible > :global(*) {
    transform: translateY(calc(0.1rem * -1));
    transition: transform 250ms cubic-bezier(0.33, 1, 0.68, 1);
  }

  .site-title a:hover {
    transform: translateY(calc(0.1rem * -1));
    transition: transform 250ms cubic-bezier(0.33, 1, 0.68, 1);
  }
</style>
